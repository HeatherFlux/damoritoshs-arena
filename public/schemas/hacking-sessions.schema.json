{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://damoritoshs-arena.pages.dev/schemas/hacking-sessions.schema.json",
  "title": "Hacking Sessions",
  "description": "Array of saved SF2e hacking encounters with computer stat blocks",
  "x-player-visibility": {
    "_summary": "The hacking module has a separate Player View (a fullscreen canvas the GM can share or project). Players see the computer name and the visible (non-hidden) access points on the network graph — but no DCs, skills, vulnerabilities, countermeasures, or notes. DO NOT PUT SPOILERS IN PLAYER-VISIBLE FIELDS.",
    "PLAYER_VISIBLE": [
      "computer.name   ← shown in the player view header",
      "accessPoints[].name   ← rendered next to each visible node on the canvas",
      "accessPoints[].state   ← locked / active / breached / alarmed badge",
      "accessPoints[].position   ← where the node sits on the canvas",
      "accessPoints[].connectedTo   ← only edges between visible nodes are drawn"
    ],
    "GM_ONLY": [
      "computer.description / successDescription / criticalSuccessDescription / failureDescription",
      "computer.level / type",
      "accessPoints[].dc",
      "accessPoints[].successesRequired",
      "accessPoints[].hackSkills[]",
      "accessPoints[].vulnerabilities[]   ← every field, including names and skills",
      "accessPoints[].countermeasures[]   ← every field, including descriptions",
      "accessPoints[].notes   ← GM session notes",
      "accessPoints[].hidden   ← hidden nodes are not drawn at all in the player view"
    ],
    "AUTHORING_RULES": [
      "1. Node and computer names are visible — use evocative but non-spoilery names. 'The Voice's Anchor' is fine if the daemon is already named; 'Daemon's Anchor' before the reveal is a leak.",
      "2. Set hidden: true on access points whose presence would tip the surprise (a back-room 'Black Budget Log', a hidden chorus subprocess, etc.). The GM toggles it visible at the right moment.",
      "3. Vulnerability and countermeasure names/descriptions are GM-only — safe to be detailed and revealing.",
      "4. notes is for GM session prep — Perception DCs to spot a node, ambient noise modifiers, when to reveal hidden subsystems, etc.",
      "5. The computer's success/failure descriptions are GM-only — they describe the overall encounter outcome, not what individual nodes do. Safe to put plot reveals there if needed."
    ]
  },
  "x-import-info": {
    "storeMethod": "hackingStore.state.savedEncounters (merge directly)",
    "notes": "Each saved encounter wraps a Computer object. The computer defines access points, vulnerabilities, and countermeasures per SF2e rules.",
    "exampleFile": "/schemas/examples/hacking-sessions.example.json"
  },
  "type": "array",
  "items": {
    "$ref": "#/definitions/SavedHackingEncounter"
  },
  "definitions": {
    "SavedHackingEncounter": {
      "type": "object",
      "required": ["id", "name", "computer", "savedAt"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "computer": { "$ref": "#/definitions/Computer" },
        "savedAt": { "type": "number", "description": "Unix timestamp in milliseconds" }
      }
    },
    "Computer": {
      "type": "object",
      "required": ["id", "name", "level", "type", "accessPoints"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "integer", "minimum": 0, "maximum": 20 },
        "type": { "type": "string", "enum": ["tech", "magic", "hybrid"] },
        "description": { "type": "string" },
        "successDescription": { "type": "string" },
        "criticalSuccessDescription": { "type": "string" },
        "failureDescription": { "type": "string" },
        "accessPoints": {
          "type": "array",
          "items": { "$ref": "#/definitions/AccessPoint" }
        }
      }
    },
    "AccessPoint": {
      "type": "object",
      "required": ["id", "name", "type", "state", "position", "connectedTo"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["physical", "remote", "magical"] },
        "state": { "type": "string", "enum": ["locked", "active", "breached", "alarmed"] },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "connectedTo": { "type": "array", "items": { "type": "string" } },
        "hidden": {
          "type": "boolean",
          "description": "When true, the access point is hidden from the player view (HackingPlayerView) until the GM reveals it. Useful for sub-systems the players shouldn't know about until they've explored the network. Defaults to false."
        },
        "dc": { "type": "integer" },
        "successesRequired": { "type": "integer", "minimum": 1 },
        "hackSkills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["skill", "dc"],
            "properties": {
              "skill": { "type": "string" },
              "dc": { "type": "integer" },
              "proficiency": { "type": "string", "enum": ["untrained", "trained", "expert", "master", "legendary"] }
            }
          }
        },
        "vulnerabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "skills", "dcReduction"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "skills": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["skill", "dc"],
                  "properties": {
                    "skill": { "type": "string" },
                    "dc": { "type": "integer" }
                  }
                }
              },
              "dcReduction": { "type": "integer", "minimum": 1, "maximum": 3 }
            }
          }
        },
        "countermeasures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "failureThreshold", "disableSkills", "description"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "failureThreshold": { "type": "integer", "minimum": 1 },
              "noticeDC": { "type": "integer" },
              "noticeSkills": { "type": "array", "items": { "type": "string" } },
              "disableSkills": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["skill", "dc"],
                  "properties": {
                    "skill": { "type": "string" },
                    "dc": { "type": "integer" }
                  }
                }
              },
              "description": { "type": "string" },
              "isPersistent": { "type": "boolean" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    }
  }
}
